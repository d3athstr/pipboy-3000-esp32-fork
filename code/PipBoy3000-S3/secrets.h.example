// PipBoy 3000 — local secrets template
//
// Copy this file to secrets.h (same folder) and set your own values.
// secrets.h is gitignored, so your passwords never land in the repo.
#pragma once

#define AP_SSID   "PIPBOY3000"        // hotspot network name
#define AP_PASS   "change-me-please"  // hotspot WPA2 password (min 8 chars)
#define OTA_PASS  "change-me-too"     // ArduinoOTA password
